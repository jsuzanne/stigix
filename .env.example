# Prisma SD-WAN Credentials
# Required for site auto-detection and flow browser queries
PRISMA_SDWAN_REGION=de
PRISMA_SDWAN_TSGID=your-tsg-id
PRISMA_SDWAN_CLIENT_ID=your-client-id@tsgid.iam.panserviceaccount.com
PRISMA_SDWAN_CLIENT_SECRET=your-client-secret

# JWT Secret for Web UI Authentication
JWT_SECRET=super-secret-key-change-this

# Infrastructure Settings
CONFIG_DIR=./config
LOG_DIR=./logs
DASHBOARD_REFRESH_MS=1000

# Stigix Registry (Optional)
STIGIX_REGISTRY_ENABLED=true
STIGIX_REGISTRY_URL=https://stigix-registry.jlsuzanne.workers.dev
STIGIX_REGISTRY_API_KEY=your-global-registry-key
STIGIX_REGISTRY_HEARTBEAT_SEC=300
STIGIX_REGISTRY_DISCOVERY_SEC=120
STIGIX_REGISTRY_MODE=peer # 'leader' or 'peer'
