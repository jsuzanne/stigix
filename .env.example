# Stigix - Environment Configuration Example

# --- General & Security ---
# Internal port for the Dashboard
PORT=8080
# Secret for session tokens (Required for MCP & Dashboard auth)
# Generate a secure random string!
JWT_SECRET=your-secure-secret-here
# Enable verbose backend logging (true/false)
DEBUG=false

# --- Deployment Role ---
# Role can be: both, target, or source
STIGIX_ROLE=both
# Custom site name for dashboard display
STIGIX_SITE_NAME=local-node

# --- Prisma SD-WAN API (Optional) ---
# Required for Cloud Autodiscovery, Flow Search, and SaaS enrichment
# PRISMA_SDWAN_REGION=Germany
# PRISMA_SDWAN_TSGID=
# PRISMA_SDWAN_CLIENT_ID=
# PRISMA_SDWAN_CLIENT_SECRET=

# --- Registry & Autodiscovery (JL Workers) ---
STIGIX_REGISTRY_ENABLED=true
STIGIX_REGISTRY_URL=https://stigix-registry.jlsuzanne.workers.dev
STIGIX_TARGET_BASE_URL=https://stigix-target.jlsuzanne.workers.dev

# --- Traffic Generator ---
AUTO_START_TRAFFIC=true
SLEEP_BETWEEN_REQUESTS=1
CLIENT_ID=client01

# --- Local Target Simulation (8082) ---
# Baseline latency for SLOW modes (seconds)
SLOW_DELAY_SECONDS=5
# Port for the local target service
TARGET_HTTP_PORT=8082

# --- XFR Bandwidth Testing ---
# Port for XFR throughput testing
XFR_PORT=9000
# Max bandwidth rate allowed (Mbps)
XFR_RATE_LIMIT=2
# Max duration per test run (seconds)
XFR_MAX_DURATION=60
